# SoftwareTeamFabrik - Environment Configuration
# Copy this file to .env and fill in your API keys
# NEVER commit .env to version control (it's in .gitignore)

# Required: GitLab Personal Access Token
# Generate at: https://gitlab.your-instance.com/-/profile/personal_access_tokens
# Needs: api scope
GITLAB_TOKEN=your-gitlab-personal-access-token

# Required: GitLab instance URL
# Set this to your GitLab instance URL (e.g., https://gitlab.com or https://gitlab.your-company.com)
GITLAB_URL=https://gitlab.your-company.com

# Required: GitLab Project Path
# Set this to your project path (e.g., namespace/project-name)
GITLAB_PROJECT=your-group/your-project

# Optional: Anthropic API Key (for Code Reviewer, Architect, Research Agent)
# Generate at: https://console.anthropic.com/account/keys
# Used by: claude-sonnet-4-6, claude-opus-4-7
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: Mistral API Key (for Developer, QA Engineer)
# Generate at: https://console.mistral.ai/api-keys/
# Used by: mistral-small, mistral-large-latest
# Note: Final scope keys cannot access Devstral models
MISTRAL_API_KEY=your-mistral-api-key

# Optional: Ollama Configuration (for local LLM inference)
# Ollama runs locally without authentication by default
# Base URL for the Ollama API endpoint
# On Linux, replace with the host's IP (e.g. 172.17.0.1) or use --add-host=host.docker.internal:host-gateway
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Optional API key (only needed if your Ollama server requires authentication)
OLLAMA_API_KEY=
# Request timeout in seconds (1-600, default: 120)
OLLAMA_TIMEOUT=120
